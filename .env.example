# ─── Nova Suite Environment Configuration ───
# Copy this file to .env and edit the values below.
# Canonical env docs: docs/ENVIRONMENT.md

# ─── PostgreSQL ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nova
POSTGRES_USER=nova_app
POSTGRES_PASSWORD=CHANGE_ME_TO_RANDOM_SECRET
DB_SCHEMA_VERSION=v00.01.00

# ─── JWT ───
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=8h

# ─── Auth mode ───
# Set to false to enforce SSO-only login (hide password login UI + block /api/auth/login)
AUTH_LOCAL_LOGIN_ENABLED=true

# ─── API ───
API_PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# ─── Temporal (workflow engine) ───
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=nova-itsm
TEMPORAL_RETENTION_DAYS=30
# Same long random string on nova-engine and nova-worker; used with pgp_sym_encrypt for tenant_credentials (≥16 chars recommended).
CREDENTIALS_MASTER_KEY=
# Shared key for internal catalog automation endpoints (set same value on nova-engine and nova-worker).
# If the value contains "$", escape it as "$$" in .env (docker compose variable interpolation).
CATALOG_AUTOMATION_SHARED_KEY=
# Duration for auto-setup when it creates the default namespace (first boot only). Use 24h × TEMPORAL_RETENTION_DAYS (e.g. 30d → 720h). Existing namespaces: update with `temporal operator namespace update … --retention …`.
DEFAULT_NAMESPACE_RETENTION=720h

# ─── Mail notifications (worker) ───
# Disabled by default; enable gradually per environment.
MAIL_NOTIFICATIONS_ENABLED=false
MAIL_FROM=no-reply@nova.local
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ─── Redis (optional – caching) ───
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379
REDIS_DEFAULT_TTL_SECONDS=300

# ─── CORS ───
CORS_ORIGIN=*

# ─── OpenID Connect (optional SSO) ───
# Example (Google): OIDC_ISSUER=https://accounts.google.com
# Example (Entra ID): OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost/api/auth/sso/callback
OIDC_PROVIDER_NAME=Google
OIDC_SCOPE=openid email profile

# ─── Uploads ───
UPLOAD_MAX_FILE_SIZE_MB=20

# ─── Web i18n (Vite) ───
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,de,de-ch,fr,it
VITE_LOCALE_STORAGE_KEY=nova_locale
VITE_LOCALE_PREFERENCE_SCOPE=ui:locale
